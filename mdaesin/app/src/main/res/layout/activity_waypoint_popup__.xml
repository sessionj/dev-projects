<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#eeeeee"
    tools:context=".ui.popup.WaypointPopupActivity">

    <!-- 타이틀바 -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:text="@string/title_history"
            android:textSize="20sp"
            android:textColor="#fff"
            android:gravity="center"
            android:background="@color/orange_"
            android:layout_width="match_parent"
            android:layout_height="53dp" />
    </LinearLayout>
    <!-- //end 타이틀바 -->

    <!-- Notice -->
    <LinearLayout
        android:padding="24dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/waypoint_popup_content1"
            android:textSize="15sp"
            android:textColor="#000"
            android:alpha="0.87"
            android:gravity="left"
            android:layout_gravity="left"
            android:layout_marginBottom="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/waypoint_popup_content2"
            android:textSize="15sp"
            android:textColor="#000"
            android:alpha="0.87"
            android:gravity="left"
            android:layout_gravity="left"
            android:layout_marginBottom="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@+id/waypoint_popup_content3"
            android:textSize="15sp"
            android:textColor="#000"
            android:alpha="0.87"
            android:gravity="left"
            android:layout_gravity="left"
            android:layout_marginBottom="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@+id/waypoint_popup_content4"
            android:textSize="15sp"
            android:textColor="#000"
            android:alpha="0.87"
            android:gravity="left"
            android:layout_gravity="left"
            android:layout_marginBottom="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@+id/popup_content5"
            android:textSize="15sp"
            android:textColor="#000"
            android:alpha="0.87"
            android:gravity="left"
            android:layout_gravity="left"
            android:layout_marginBottom="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <!-- Notice -->

    <View
        android:background="#66bdbdbd"
        android:layout_width="match_parent"
        android:layout_height="1dp" />

    <!-- 닫기 버튼 -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Button
            android:text="확인"
            android:textSize="15sp"
            android:textColor="@color/grey_90"
            android:padding="16dp"
            android:gravity="center"
            android:background="#00000000"
            android:layout_width="match_parent"
            android:layout_height="53dp"
            android:onClick="mOnClose"/>
    </LinearLayout>
    <!--// 닫기 버튼 -->

</LinearLayout>