<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DeliveryDetailsActivity">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="10dp"
    android:layout_marginBottom="5dp"
    >
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="MissingConstraints"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_marginTop="5dp"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_bottom">


            <TextView
                android:layout_weight="1"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="배달자 : 홍길동"
                android:textSize="20dp"
                android:gravity="left"
                >
            </TextView>
            <TextView
                android:layout_weight="1"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="2022-04-19 (화)"
                android:textSize="20dp"
                android:gravity="center"
                >
            </TextView>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="충북 청주시 흥덕구 송화로 214번길 29 테크노 폴리스 우미린 106-1803호"
            android:textSize="18dp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            >
        </TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="홍길동 | 010-1234-5678, 010-0987-5432"
            android:textSize="16dp"
            android:background="@drawable/gradient_bottom"
            android:layout_marginTop="10dp"
            >
        </TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="자동차부품 | 박스"
            android:textSize="18dp"
            android:textColor="@color/red"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            >
        </TextView>
        <LinearLayout
            android:id="@+id/map_view"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:tooltipText="@string/request_course_2"
            tools:ignore="Orientation"
            android:layout_marginTop="15dp"
            />
        <Button
            android:id="@+id/details_success_btn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/red"
            android:text="배달 처리"
            android:textSize="20dp"
            android:layout_marginTop="15dp"
            />

    </LinearLayout>

</ScrollView>



</RelativeLayout>