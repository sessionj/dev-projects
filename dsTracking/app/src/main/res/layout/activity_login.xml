<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.LoginActivity"
    android:background="@color/grey_90"
    >


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="200dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/login_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/app_name_login"
            android:textColor="@color/white"
            android:textSize="22dp" />

        <ProgressBar
            android:id="@+id/receipt_login_progressBar"
            android:layout_marginTop="30dp"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:alpha="0.3"
            android:layout_gravity="center"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="40dp"
            android:layout_marginTop="5dp"
            android:gravity="center_horizontal">



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:errorEnabled="true"
            app:passwordToggleEnabled="true"
            >

            <EditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="number"
                android:id="@+id/user_phone_number"
                android:hint="@string/hint_question"
                android:textColor="@color/white"
                android:textColorHint="@color/grey_60"
                android:backgroundTint ="@color/coursor"
                android:textCursorDrawable="@color/coursor"
                android:layout_weight="1"
                android:textSize="12dp"
                android:gravity="center"
                />
            <Button
                android:id="@+id/request_btn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:textSize="12dp"
                android:text="인증요청"
                />
        </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:errorEnabled="true"
                app:passwordToggleEnabled="true"
                android:id="@+id/area_agency">

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:inputType="number"
                    android:id="@+id/response_key"
                    android:hint="@string/hint_answer"
                    android:textColor="@color/white"
                    android:textColorHint="@color/grey_60"
                    android:layout_weight="1"
                    android:backgroundTint ="@color/coursor"
                    android:textCursorDrawable="@color/coursor"
                    android:textSize="12dp"
                    android:gravity="center"
                    />
                <Button
                    android:id="@+id/certification_btn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:textSize="12dp"
                    android:text="확인"
                    />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>




</LinearLayout>