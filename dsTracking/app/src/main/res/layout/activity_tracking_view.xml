<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.TrackingViewActivity"
    android:background="@color/white"
    >

    <androidx.core.widget.NestedScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/edit_scrollView"
        android:layout_height="wrap_content"
        android:layout_width="match_parent">

        <LinearLayout
            android:id="@+id/details_linear"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            tools:layout_editor_absoluteX="8dp"
            tools:layout_editor_absoluteY="8dp"
            android:padding="15dp"
            >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    >

                    <ImageView
                        android:id="@+id/star"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:padding="3dp"
                        android:src="@drawable/btn_on1"
                        android:layout_marginTop="1dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/white"
                        android:text="기본 정보"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:background="@drawable/gradient"
                    android:orientation="vertical"

                    >
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingTop="10dp"
                        android:orientation="horizontal"
                        >
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:text="택배사"
                            android:gravity="center"
                            android:layout_weight="2"
                            android:background="@drawable/gradient_bottom"
                            android:layout_marginLeft="10dp"
                            android:textSize="14dp"
                            android:textColor="@color/grey_40"
                            />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="대신택배"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/gradient_bottom"
                            android:layout_weight="1"
                            android:gravity="left|center"
                            android:textSize="14dp"
                            android:textColor="@color/grey_80"

                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingTop="10dp"
                        android:orientation="horizontal"
                        >
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:text="운송장번호"
                            android:gravity="center"
                            android:layout_weight="2"
                            android:background="@drawable/gradient_bottom"
                            android:layout_marginLeft="10dp"
                            android:textSize="14dp"
                            android:textColor="@color/grey_40"/>
                        <TextView
                            android:id="@+id/tracking_view_billno"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="4001-251-0000001"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/gradient_bottom"
                            android:layout_weight="1"
                            android:gravity="left|center"
                            android:textSize="14dp"
                            android:textColor="@color/grey_80"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingTop="10dp"
                        android:orientation="horizontal"
                        >
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:text="상품정보"
                            android:gravity="center"
                            android:layout_weight="2"
                            android:background="@drawable/gradient_bottom"
                            android:layout_marginLeft="10dp"
                            android:textSize="14dp"
                            android:textColor="@color/grey_40"/>
                        <TextView
                            android:id="@+id/tracking_view_goods"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="묠니르 | 우르 | 1개"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/gradient_bottom"
                            android:layout_weight="1"
                            android:gravity="left|center"
                            android:textSize="14dp"
                            android:textColor="@color/grey_80"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingTop="10dp"
                        android:orientation="horizontal"
                        >
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:text="보내는분"
                            android:gravity="center"
                            android:layout_weight="2"
                            android:background="@drawable/gradient_bottom"
                            android:layout_marginLeft="10dp"
                            android:textSize="14dp"
                            android:textColor="@color/grey_40"/>
                        <TextView
                            android:id="@+id/tracking_view_sendingman"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="토르(010-0000-0202)"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/gradient_bottom"
                            android:layout_weight="1"
                            android:gravity="left|center"
                            android:textSize="14dp"
                            android:textColor="@color/grey_80"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingTop="10dp"
                        android:orientation="horizontal"
                        >
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:text="받는분"
                            android:gravity="center"
                            android:layout_weight="2"
                            android:layout_marginLeft="10dp"
                            android:textSize="14dp"
                            android:textColor="@color/grey_40"
                            />
                        <TextView
                            android:id="@+id/tracking_view_arrivalman"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="토니 스타크(010-0000-0201)"
                            android:layout_marginRight="10dp"
                            android:layout_weight="1"
                            android:gravity="left|center"
                            android:textSize="14dp"
                            android:textColor="@color/grey_80"
                            />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
            <ProgressBar
                android:id="@+id/tracking_view_progressBar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:alpha="0.3"
                android:layout_gravity="center"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:orientation="horizontal"
                android:paddingTop="6dp"
                >
                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:padding="3dp"
                    android:src="@drawable/btn_on1"
                    android:layout_marginTop="1dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/white"
                    android:text="운송 정보"/>
            </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/gradient"
            android:orientation="vertical"

            >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="10dp"
                android:orientation="horizontal"
                android:background="@drawable/gradient_table_bottom"
                >
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:text="구분"
                    android:gravity="center"
                    android:layout_marginLeft="10dp"
                    android:textSize="14dp"
                    android:textColor="@color/color1"
                    android:layout_weight="1"
                    />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:text="취급점명"
                    android:gravity="center"
                    android:layout_marginLeft="10dp"
                    android:textSize="14dp"
                    android:textColor="@color/color1"
                    android:layout_weight="1"
                    />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:text="전화번호"
                    android:gravity="center"
                    android:layout_marginLeft="10dp"
                    android:textSize="14dp"
                    android:textColor="@color/color1"
                    android:layout_weight="1"
                    />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:text="도착일자"
                    android:gravity="center"
                    android:layout_marginLeft="10dp"
                    android:textSize="14dp"
                    android:textColor="@color/color1"
                    android:layout_weight="1"
                    />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:text="출발일자"
                    android:gravity="center"
                    android:layout_marginLeft="10dp"
                    android:textSize="14dp"
                    android:textColor="@color/color1"
                    android:layout_weight="1"
                    />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:text="비고"
                    android:gravity="center"
                    android:layout_marginLeft="10dp"
                    android:textSize="14dp"
                    android:textColor="@color/color1"
                    android:layout_weight="1"
                    />

            </LinearLayout>

        </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tracking_view_recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="3dp"
                />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>


</LinearLayout>