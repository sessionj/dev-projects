<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="90dp"
    android:layout_marginTop="7dp"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="15dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:background="@drawable/gradient"
        >
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/tracking_row_item_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:textColor="@color/purple_700"
                android:textSize="16dp"
                android:textStyle="bold"
                android:text="부곡터남해(노선명)">
            </TextView>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp">
            <ImageView
                android:id="@+id/star"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:padding="3dp"
                android:src="@drawable/bul"
                android:layout_marginTop="1dp"
                >
            </ImageView>

            <TextView
                android:id="@+id/tracking_row_item_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" 4001-501-0000001 | 토니스타크"
                android:textColor="@color/grey_90"
                android:textSize="13dp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp">
            <ImageView
                android:id="@+id/star2"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:padding="3dp"
                android:src="@drawable/bul"
                android:layout_marginTop="1dp"/>

            <TextView
                android:id="@+id/tracking_row_item_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="배송완료"
                android:textColor="@color/orange"
                android:textSize="14dp"
                />
            <TextView
                android:id="@+id/tracking_row_item_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / 리뷰1+ / 사장님댓글1+ / 100m"
                android:textColor="@color/grey_90"
                android:textSize="13dp"
                android:paddingLeft="2dp"
                />

        </LinearLayout>

    </LinearLayout>


</LinearLayout>